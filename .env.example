# search-arena — copy to .env and fill in the keys you have.
# Keys are loaded by arena/secrets.py (.env first, Doppler overlays if configured).
# Only ANTHROPIC_API_KEY is required; every provider key is optional — the arena runs
# across whichever providers have a key present (see the SCOPE section of the output).

# ── Required ─────────────────────────────────────────────────────────────────
# The judge, reader, and grader run on the Anthropic API — needed for every run.
# Also enables the claude_search provider (Claude's native web search baseline).
#ANTHROPIC_API_KEY=

# ── Optional providers (any subset; each key adds one provider to the arena) ─
#TAVILY_API_KEY=
#EXA_API_KEY=
#BRAVE_API_KEY=
#SERPER_API_KEY=
#PERPLEXITY_API_KEY=          # enables both perplexity_search and perplexity (Sonar)
#FIRECRAWL_API_KEY=
#LINKUP_API_KEY=
#YOU_API_KEY=
#PARALLEL_API_KEY=
# Gemini accepts either key (GEMINI_API_KEY checked first):
#GEMINI_API_KEY=
#GOOGLE_API_KEY=

# ── Optional extras ──────────────────────────────────────────────────────────
# Cross-family secondary judge (config judge.secondary: "openai:<model>") and the
# OpenAI SimpleQA grader:
#OPENAI_API_KEY=
# Langfuse tracing — all three needed, plus config langfuse.enabled: true:
#LANGFUSE_PUBLIC_KEY=
#LANGFUSE_SECRET_KEY=
#LANGFUSE_HOST=
